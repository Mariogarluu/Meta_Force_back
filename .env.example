# Solo para desarrollo local con Supabase CLI (db push, link).
# Copia a .env y rellena con valores del dashboard del proyecto.

# URL de conexión Postgres (pooler o directa según tu flujo)
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=tu_publishable_o_anon_key

# Opcional: despliegue de funciones desde CI
# SUPABASE_ACCESS_TOKEN=
