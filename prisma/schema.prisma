generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String
  passwordHash     String
  role             Role              @default(USER)
  status           UserStatus        @default(PENDING)
  profileImageUrl  String? // URL de la imagen de perfil en Cloudinary
  gender           String?
  birthDate        DateTime?
  height           Float?         // en cm
  currentWeight    Float?         // en kg
  medicalNotes     String?        // para enfermedades, etc.
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  centerId         String? // Centro actual
  center           Center?        @relation("CurrentCenter", fields: [centerId], references: [id], onDelete: SetNull)
  favoriteCenterId String? // Centro favorito
  favoriteCenter   Center?        @relation("FavoriteCenter", fields: [favoriteCenterId], references: [id], onDelete: SetNull)
  classes          GymClass[] @relation("GymClassToUser") // Clases a las que asiste como usuario
  trainedClasses   ClassTrainer[] @relation("ClassTrainer") // Clases que enseña como entrenador
  notifications    Notification[]
  workouts         Workout[] @relation("UserWorkouts") // Entrenamientos del usuario
  diets            Diet[] @relation("UserDiets") // Dietas del usuario
  chatSessions     AiChatSession[]
  measurements     UserMeasurement[]
  exerciseLogs     ExerciseLog[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  type      String   @default("INFO")
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Center {
  id             String                @id @default(cuid())
  name           String                @unique
  description    String?
  address        String?
  city           String?
  country        String?
  phone          String?
  email          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  classSchedules ClassCenterSchedule[] @relation("ClassSchedules")
  machines       Machine[]
  tickets        Ticket[]              @relation("CenterTickets")
  currentUsers   User[]                @relation("CurrentCenter")
  favoriteUsers  User[]                @relation("FavoriteCenter")
}

model MachineType {
  id        String     @id @default(cuid())
  name      String
  type      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  exercises Exercise[] @relation("MachineTypeExercises")
  machines  Machine[]

  @@unique([name, type])
}

model Machine {
  id             String      @id @default(cuid())
  machineTypeId  String
  instanceNumber Int
  status         String
  centerId       String
  maxUsers       Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  center         Center      @relation(fields: [centerId], references: [id], onDelete: Cascade)
  machineType    MachineType @relation(fields: [machineTypeId], references: [id], onDelete: Cascade)

  @@unique([machineTypeId, centerId, instanceNumber])
  @@index([centerId])
  @@index([machineTypeId])
}

model GymClass {
  id          String                @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  schedules   ClassCenterSchedule[]
  trainers    ClassTrainer[]
  users       User[]                @relation("GymClassToUser")
}

model ClassTrainer {
  id        String   @id @default(cuid())
  classId   String
  trainerId String
  createdAt DateTime @default(now())
  class     GymClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  trainer   User     @relation("ClassTrainer", fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([classId, trainerId])
  @@index([classId])
  @@index([trainerId])
}

model ClassCenterSchedule {
  id        String   @id @default(cuid())
  classId   String
  centerId  String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  center    Center   @relation("ClassSchedules", fields: [centerId], references: [id], onDelete: Cascade)
  class     GymClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([centerId])
  @@index([classId, centerId])
}

model Ticket {
  id          String    @id @default(cuid())
  name        String
  email       String
  phone       String?
  centerId    String
  subject     String
  description String
  attachments String[]
  status      String    @default("pending")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  center      Center    @relation("CenterTickets", fields: [centerId], references: [id], onDelete: Cascade)

  @@index([centerId])
  @@index([status])
  @@index([createdAt])
}

model Exercise {
  id               String            @id @default(cuid())
  name             String
  description      String?
  instructions     String?
  imageUrl         String?
  videoUrl         String?
  machineTypeId    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  machineType      MachineType?      @relation("MachineTypeExercises", fields: [machineTypeId], references: [id])
  exerciseLogs     ExerciseLog[]
  workoutExercises WorkoutExercise[]

  @@index([machineTypeId])
}

model Workout {
  id          String            @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation("UserWorkouts", fields: [userId], references: [id], onDelete: Cascade)
  exercises   WorkoutExercise[]

  @@index([userId])
}

model WorkoutExercise {
  id          String   @id @default(cuid())
  workoutId   String
  exerciseId  String
  dayOfWeek   Int
  order       Int
  sets        Int?
  reps        Int?
  weight      Float?
  duration    Int?
  restSeconds Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId])
  @@index([exerciseId])
  @@index([workoutId, dayOfWeek])
}

model Meal {
  id           String     @id @default(cuid())
  name         String     @unique
  description  String?
  instructions String?
  imageUrl     String?
  calories     Float?
  protein      Float?
  carbs        Float?
  fats         Float?
  fiber        Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  dietMeals    DietMeal[]
}

model Diet {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation("UserDiets", fields: [userId], references: [id], onDelete: Cascade)
  meals       DietMeal[]

  @@index([userId])
}

model DietMeal {
  id        String   @id @default(cuid())
  dietId    String
  mealId    String
  dayOfWeek Int
  mealType  String
  order     Int
  quantity  Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  diet      Diet     @relation(fields: [dietId], references: [id], onDelete: Cascade)
  meal      Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([dietId])
  @@index([mealId])
  @@index([dietId, dayOfWeek])
}

model MembershipPlan {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  duration    Int
  features    String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model AiChatSession {
  id        String          @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  AiChatMessage[]
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiChatMessage {
  id        String        @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime      @default(now())
  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model UserMeasurement {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  weight    Float?
  bodyFat   Float?
  bmi       Float?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model ExerciseLog {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  date       DateTime @default(now())
  sets       Int?
  reps       Int?
  weight     Float?
  notes      String?
  createdAt  DateTime @default(now())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([exerciseId])
  @@index([date])
}

enum Role {
  SUPERADMIN
  ADMIN_CENTER
  TRAINER
  CLEANER
  USER
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
}
