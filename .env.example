# Configuración General del Servidor
PORT=3000
NODE_ENV=development

# 🔐 Seguridad y Autenticación
JWT_SECRET=SUPER_SECRETO_DE_AL_MENOS_32_CARACTERES
BCRYPT_SALT_ROUNDS=10

# 💾 Conexión a Base de Datos (Para Desarrollo Local - se usa la URL completa)
DATABASE_URL=postgresql://user:password@localhost:5432/db_name?schema=public
# Si en producción DATABASE_URL usa el pooler de Supabase (:6543), para `prisma migrate deploy`
# suele necesitarse una URL directa (:5432). En ese caso añade en schema.prisma `directUrl = env("DIRECT_URL")` y:
# DIRECT_URL=postgresql://...@db.xxx.supabase.co:5432/postgres

# ☁️ Variables de Conexión de Render (Se usan en Producción cuando DATABASE_URL falta)
DB_HOST=RENDER_DB_HOSTNAME_EJEMPLO
DB_PORT=RenderPORT
DB_DATABASE=RENDER_DB_NAME
DB_USER=RENDER_DB_USER
DB_PASSWORD=RENDER_DB_PASSWORD

# Supabase (Storage + cliente; obligatorias en env.ts)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=tu_anon_key

# Edge Functions IA (opcional en Vercel si despliegas ai-chat / ai-sessions / ai-save-plan)
# Base: https://xxxx.supabase.co/functions/v1  (sin barra final)
SUPABASE_EDGE_FUNCTIONS_URL=
# GEMINI_API_KEY puede vivir solo en secretos de Supabase Edge si usas el proxy anterior.

# Ticket público por Edge (JSON + adjuntos base64), alternativa a POST /api/tickets multipart:
# URL tras deploy: https://<ref>.supabase.co/functions/v1/create-ticket

# IA (Gemini) — en el API Node si no usas Edge para chat
GEMINI_API_KEY=