# Solo para desarrollo local con Supabase CLI (db push, link).
# Copia a .env y rellena con valores del dashboard del proyecto.

# URL de conexión Postgres (pooler o directa según tu flujo)
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=tu_publishable_o_anon_key

# Opcional: despliegue de funciones desde CI / scripts/apply-analytics-rls.mjs (front)
# SUPABASE_ACCESS_TOKEN=

# Scripts locales (scripts/apply-analytics-rls.js, seed-from-json.mjs)
# Nunca commitear SUPABASE_SERVICE_ROLE_KEY en código fuente.

# Clave de servicio (solo para backend / Edge Functions, nunca en el frontend)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_solo_backend

# Resend (envío de emails de suscripciones)
RESEND_API_KEY=tu_api_key_de_resend
RESEND_FROM="Meta Force <facturacion@tudominio.com>"

# Firma de JWT para QR de acceso (Edge Function qr-sign)
JWT_QR_SECRET=una_clave_larga_y_secreta_para_qr
