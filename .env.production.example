NODE_ENV=production

# URL de conexión al pooler de Supabase para migraciones fuera de Edge (CLI, scripts puntuales)
# Ejemplo: postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Variables públicas del proyecto Supabase (reflejadas en el front)
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=tu_publishable_o_anon_key

# API key de Groq (https://console.groq.com/keys) — free tier sin tarjeta
GROQ_API_KEY=gsk_tu_clave_aqui
# Opcional: modelo (default llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile